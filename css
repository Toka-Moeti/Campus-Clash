:root {
  --bg: #09090b;
  --surface: #141417;
  --text: #f7f7f8;
  --muted: #b6b6bd;
  --accent: #f5ba31;
  --border: rgba(255, 255, 255, 0.12);
  --shadow: 0 22px 70px rgba(0, 0, 0, 0.45);
  --radius: 22px;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  min-width: 320px;
  margin: 0;
  overflow-x: hidden;
  color: var(--text);
  font-family: Arial, Helvetica, sans-serif;
  background:
    radial-gradient(circle at 80% 4%, rgba(245, 186, 49, 0.13), transparent 28rem),
    radial-gradient(circle at 5% 30%, rgba(85, 83, 255, 0.1), transparent 32rem),
    var(--bg);
}

a {
  color: inherit;
  text-decoration: none;
}

.container {
  width: min(1120px, calc(100% - 2rem));
  margin: 0 auto;
}

.site-header {
  position: fixed;
  z-index: 10;
  top: 0;
  left: 0;
  width: 100%;
  border-bottom: 1px solid transparent;
  transition: 200ms ease;
}

.site-header.is-scrolled {
  border-color: var(--border);
  background: rgba(9, 9, 11, 0.82);
  backdrop-filter: blur(14px);
}

.header-inner {
  display: flex;
  min-height: 74px;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.brand {
  display: flex;
  align-items: center;
  gap: 0.7rem;
  font-weight: 900;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.brand-mark {
  display: grid;
  width: 34px;
  height: 34px;
  place-items: center;
  border: 2px solid var(--accent);
  border-radius: 10px;
  color: var(--accent);
  transform: rotate(-8deg);
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 1.3rem;
  color: var(--muted);
  font-size: 0.92rem;
  font-weight: 700;
}

.nav-links a:hover {
  color: var(--accent);
}

.nav-button {
  padding: 0.65rem 0.95rem;
  border-radius: 999px;
  color: #15100a;
  background: var(--accent);
}

.nav-button:hover {
  color: #15100a !important;
  background: #ffd468;
}

.hero {
  display: grid;
  min-height: 100vh;
  align-items: center;
  padding: 8.5rem 0 4rem;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1.05fr 0.95fr;
  align-items: center;
  gap: 2.5rem;
}

.eyebrow {
  margin: 0 0 1.15rem;
  color: var(--accent);
  font-size: 0.78rem;
  font-weight: 900;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

h1 {
  max-width: 730px;
  margin: 0;
  font-size: clamp(3.2rem, 8vw, 7.2rem);
  line-height: 0.88;
  letter-spacing: -0.075em;
  text-transform: uppercase;
}

h1 span {
  display: block;
  color: var(--accent);
}

.hero-copy {
  max-width: 590px;
  margin: 1.5rem 0 0;
  color: var(--muted);
  font-size: 1.1rem;
  line-height: 1.75;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.9rem;
  margin-top: 2rem;
}

.button {
  display: inline-flex;
  min-height: 48px;
  align-items: center;
  justify-content: center;
  padding: 0.8rem 1.2rem;
  border: 1px solid transparent;
  border-radius: 12px;
  font-weight: 900;
  transition: 180ms ease;
}

.button:hover {
  transform: translateY(-3px);
}

.button-primary {
  color: #15100a;
  background: var(--accent);
}

.button-primary:hover {
  background: #ffd468;
}

.button-secondary {
  border-color: var(--border);
  background: rgba(255, 255, 255, 0.04);
}

.button-secondary:hover {
  border-color: rgba(245, 186, 49, 0.7);
  background: rgba(245, 186, 49, 0.1);
}

.visual-wrap {
  position: relative;
  display: grid;
  min-height: 520px;
  place-items: center;
  perspective: 1100px;
}

.glow {
  position: absolute;
  width: min(88vw, 470px);
  aspect-ratio: 1;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(245, 186, 49, 0.3),
    rgba(245, 186, 49, 0.08) 42%,
    transparent 70%
  );
}

.character-card {
  position: relative;
  z-index: 1;
  width: min(100%, 425px);
  padding: 1rem;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.16);
  border-radius: 28px;
  background: #17171b;
  box-shadow: var(--shadow);
  transform-style: preserve-3d;
  transition: transform 120ms linear;
}

.character-image {
  display: block;
  width: 100%;
  min-height: 425px;
  object-fit: cover;
  border-radius: 18px;
  background: #25252b;
}

.badge {
  position: absolute;
  right: -1rem;
  bottom: 2rem;
  max-width: 210px;
  padding: 1rem;
  border: 1px solid rgba(245, 186, 49, 0.45);
  border-radius: 14px;
  background: rgba(10, 10, 12, 0.88);
  box-shadow: 0 18px 38px rgba(0, 0, 0, 0.25);
}

.badge span {
  display: block;
  color: var(--accent);
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.badge strong {
  display: block;
  margin-top: 0.35rem;
}

.section {
  padding: 6rem 0;
}

.section-alt {
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.025);
}

.section-heading {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 2rem;
  margin-bottom: 2rem;
}

.section-heading h2,
.join-panel h2 {
  max-width: 700px;
  margin: 0;
  font-size: clamp(2rem, 4.5vw, 4rem);
  line-height: 0.96;
  letter-spacing: -0.055em;
  text-transform: uppercase;
}

.section-heading p {
  max-width: 440px;
  margin: 0;
  color: var(--muted);
  line-height: 1.7;
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.info-card {
  min-height: 230px;
  padding: 1.5rem;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: rgba(255, 255, 255, 0.04);
}

.card-number {
  color: var(--accent);
  font-size: 0.78rem;
  font-weight: 900;
  letter-spacing: 0.12em;
}

.info-card h3 {
  margin: 2rem 0 0.75rem;
  font-size: 1.35rem;
}

.info-card p {
  margin: 0;
  color: var(--muted);
  line-height: 1.65;
}

.events-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}

.event {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.15rem;
  border: 1px solid var(--border);
  border-radius: 18px;
  background: var(--surface);
}

.event-date {
  display: grid;
  flex: 0 0 64px;
  width: 64px;
  height: 64px;
  place-items: center;
  border-radius: 14px;
  color: #17100a;
  background: var(--accent);
  font-weight: 900;
  line-height: 1;
  text-align: center;
}

.event-date small,
.event-date strong {
  display: block;
}

.event-date strong {
  font-size: 1.45rem;
}

.event h3 {
  margin: 0;
}

.event p {
  margin: 0.4rem 0 0;
  color: var(--muted);
  font-size: 0.9rem;
}

.join-panel {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 2rem;
  padding: clamp(1.5rem, 4vw, 3rem);
  border-radius: 28px;
  color: #1a1207;
  background: var(--accent);
}

.join-panel p {
  max-width: 650px;
  margin: 1rem 0 0;
  color: rgba(25, 18, 7, 0.82);
  line-height: 1.65;
}

.join-button {
  color: var(--text);
  background: #17120b;
  white-space: nowrap;
}

footer {
  padding: 2rem 0 2.5rem;
  color: var(--muted);
  font-size: 0.9rem;
}

.footer-inner {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--border);
}

@media (max-width: 820px) {
  .nav-links a:not(.nav-button) {
    display: none;
  }

  .hero-grid,
  .card-grid,
  .events-grid,
  .join-panel {
    grid-template-columns: 1fr;
  }

  .section-heading {
    display: grid;
  }

  .visual-wrap {
    min-height: 440px;
  }
}

@media (max-width: 480px) {
  .container {
    width: min(100% - 1.25rem, 1120px);
  }

  .character-image {
    min-height: 360px;
  }

  .badge {
    right: 0;
    bottom: 1rem;
  }

  .footer-inner {
    flex-direction: column;
  }
}
