<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta
    name="description"
    content="Campus Clash — Culture, community, and competition."
  />
  <title>Campus Clash</title>

  <style>
    :root {
      --bg: #09090b;
      --surface: #141417;
      --surface-soft: #1e1e23;
      --text: #f7f7f8;
      --muted: #b6b6bd;
      --accent: #f5ba31;
      --accent-dark: #e59f00;
      --border: rgba(255, 255, 255, 0.12);
      --shadow: 0 22px 70px rgba(0, 0, 0, 0.45);
      --radius: 22px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      min-width: 320px;
      overflow-x: hidden;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 80% 4%, rgba(245, 186, 49, 0.13), transparent 28rem),
        radial-gradient(circle at 5% 30%, rgba(85, 83, 255, 0.1), transparent 32rem),
        var(--bg);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button,
    a {
      -webkit-tap-highlight-color: transparent;
    }

    .container {
      width: min(1120px, calc(100% - 2rem));
      margin: 0 auto;
    }

    .site-header {
      position: fixed;
      z-index: 20;
      top: 0;
      left: 0;
      width: 100%;
      border-bottom: 1px solid transparent;
      transition: background 220ms ease, border-color 220ms ease, backdrop-filter 220ms ease;
    }

    .site-header.is-scrolled {
      background: rgba(9, 9, 11, 0.78);
      border-color: var(--border);
      backdrop-filter: blur(14px);
    }

    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 74px;
      gap: 1rem;
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 0.7rem;
      font-size: 1rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .brand-mark {
      display: grid;
      width: 34px;
      height: 34px;
      place-items: center;
      border: 2px solid var(--accent);
      border-radius: 10px;
      color: var(--accent);
      transform: rotate(-8deg);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 1.3rem;
      color: var(--muted);
      font-size: 0.92rem;
      font-weight: 700;
    }

    .nav-links a {
      transition: color 180ms ease;
    }

    .nav-links a:hover,
    .nav-links a:focus-visible {
      color: var(--accent);
    }

    .nav-button {
      padding: 0.65rem 0.95rem;
      border: 1px solid var(--accent);
      border-radius: 999px;
      color: #111;
      background: var(--accent);
      font-weight: 900;
      transition: transform 180ms ease, background 180ms ease;
    }

    .nav-button:hover,
    .nav-button:focus-visible {
      background: #ffd468;
      transform: translateY(-2px);
    }

    .hero {
      position: relative;
      display: grid;
      min-height: 100vh;
      align-items: center;
      padding: 8.5rem 0 4rem;
      overflow: hidden;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      align-items: center;
      gap: 2.5rem;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      margin: 0 0 1.15rem;
      color: var(--accent);
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .eyebrow::before {
      width: 34px;
      height: 2px;
      content: "";
      background: var(--accent);
    }

    h1 {
      max-width: 730px;
      margin: 0;
      font-size: clamp(3.2rem, 8vw, 7.2rem);
      line-height: 0.88;
      letter-spacing: -0.075em;
      text-transform: uppercase;
    }

    h1 span {
      display: block;
      color: var(--accent);
    }

    .hero-copy {
      max-width: 590px;
      margin: 1.5rem 0 0;
      color: var(--muted);
      font-size: clamp(1rem, 1.5vw, 1.15rem);
      line-height: 1.75;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
      margin-top: 2rem;
    }

    .button {
      display: inline-flex;
      min-height: 48px;
      align-items: center;
      justify-content: center;
      padding: 0.8rem 1.2rem;
      border: 1px solid transparent;
      border-radius: 12px;
      font-weight: 900;
      transition: transform 180ms ease, background 180ms ease, border-color 180ms ease;
    }

    .button:hover,
    .button:focus-visible {
      transform: translateY(-3px);
    }

    .button-primary {
      color: #15100a;
      background: var(--accent);
    }

    .button-primary:hover,
    .button-primary:focus-visible {
      background: #ffd468;
    }

    .button-secondary {
      border-color: var(--border);
      color: var(--text);
      background: rgba(255, 255, 255, 0.04);
    }

    .button-secondary:hover,
    .button-secondary:focus-visible {
      border-color: rgba(245, 186, 49, 0.7);
      background: rgba(245, 186, 49, 0.1);
    }

    .hero-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem 2rem;
      margin-top: 2.5rem;
    }

    .stat {
      min-width: 105px;
    }

    .stat strong {
      display: block;
      color: var(--accent);
      font-size: 1.55rem;
      line-height: 1;
    }

    .stat span {
      display: block;
      margin-top: 0.4rem;
      color: var(--muted);
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    .visual-wrap {
      position: relative;
      display: grid;
      min-height: 520px;
      place-items: center;
      perspective: 1100px;
    }

    .glow {
      position: absolute;
      width: min(88vw, 470px);
      aspect-ratio: 1;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(245, 186, 49, 0.3), rgba(245, 186, 49, 0.08) 42%, transparent 70%);
      filter: blur(4px);
    }

    .character-card {
      position: relative;
      z-index: 1;
      width: min(100%, 425px);
      padding: 1rem;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 28px;
      background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.03)),
        #17171b;
      box-shadow: var(--shadow);
      transform-style: preserve-3d;
      transition: transform 120ms linear;
    }

    .character-card::before {
      position: absolute;
      inset: 0;
      content: "";
      pointer-events: none;
      background: linear-gradient(125deg, rgba(255, 255, 255, 0.2), transparent 35%);
    }

    .character-image {
      display: block;
      width: 100%;
      min-height: 425px;
      object-fit: cover;
      border-radius: 18px;
      background: #25252b;
    }

    .image-fallback {
      display: grid;
      width: 100%;
      min-height: 425px;
      place-items: center;
      padding: 2rem;
      border-radius: 18px;
      color: #15100a;
      text-align: center;
      background:
        linear-gradient(140deg, transparent 0 43%, rgba(0, 0, 0, 0.07) 43% 57%, transparent 57%),
        var(--accent);
    }

    .image-fallback strong {
      display: block;
      font-size: clamp(2rem, 6vw, 4rem);
      line-height: 0.9;
      text-transform: uppercase;
    }

    .image-fallback span {
      display: block;
      margin-top: 0.8rem;
      font-size: 0.85rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .badge {
      position: absolute;
      z-index: 2;
      right: -1rem;
      bottom: 2rem;
      max-width: 210px;
      padding: 1rem;
      border: 1px solid rgba(245, 186, 49, 0.45);
      border-radius: 14px;
      color: var(--text);
      background: rgba(10, 10, 12, 0.86);
      box-shadow: 0 18px 38px rgba(0, 0, 0, 0.25);
      backdrop-filter: blur(12px);
      transform: translateZ(42px);
    }

    .badge span {
      display: block;
      color: var(--accent);
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .badge strong {
      display: block;
      margin-top: 0.35rem;
      font-size: 1rem;
    }

    .section {
      padding: 6rem 0;
    }

    .section-alt {
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.025);
    }

    .section-heading {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 2rem;
      margin-bottom: 2rem;
    }

    .section-heading h2 {
      max-width: 700px;
      margin: 0;
      font-size: clamp(2rem, 4.5vw, 4rem);
      line-height: 0.96;
      letter-spacing: -0.055em;
      text-transform: uppercase;
    }

    .section-heading p {
      max-width: 440px;
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .info-card {
      min-height: 230px;
      padding: 1.5rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: linear-gradient(160deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.015));
      transition: transform 180ms ease, border-color 180ms ease;
    }

    .info-card:hover {
      border-color: rgba(245, 186, 49, 0.6);
      transform: translateY(-6px);
    }

    .card-number {
      color: var(--accent);
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.12em;
    }

    .info-card h3 {
      margin: 2rem 0 0.75rem;
      font-size: 1.35rem;
    }

    .info-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
    }

    .events-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .event {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.15rem;
      border: 1px solid var(--border);
      border-radius: 18px;
      background: var(--surface);
    }

    .event-date {
      display: grid;
      flex: 0 0 64px;
      width: 64px;
      height: 64px;
      place-items: center;
      border-radius: 14px;
      color: #17100a;
      background: var(--accent);
      font-weight: 900;
      line-height: 1;
      text-align: center;
    }

    .event-date small {
      display: block;
      margin-bottom: 0.2rem;
      font-size: 0.7rem;
      letter-spacing: 0.08em;
    }

    .event-date strong {
      display: block;
      font-size: 1.45rem;
    }

    .event h3 {
      margin: 0;
      font-size: 1.05rem;
    }

    .event p {
      margin: 0.4rem 0 0;
      color: var(--muted);
      font-size: 0.9rem;
    }

    .join-panel {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 2rem;
      padding: clamp(1.5rem, 4vw, 3rem);
      overflow: hidden;
      border: 1px solid rgba(245, 186, 49, 0.55);
      border-radius: 28px;
      color: #1a1207;
      background:
        radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.42), transparent 34%),
        var(--accent);
    }

    .join-panel h2 {
      max-width: 650px;
      margin: 0;
      font-size: clamp(2rem, 4.2vw, 4rem);
      line-height: 0.95;
      letter-spacing: -0.055em;
      text-transform: uppercase;
    }

    .join-panel p {
      max-width: 650px;
      margin: 1rem 0 0;
      color: rgba(25, 18, 7, 0.82);
      line-height: 1.65;
    }

    .join-panel .button {
      color: var(--text);
      border-color: #17120b;
      background: #17120b;
      white-space: nowrap;
    }

    .join-panel .button:hover,
    .join-panel .button:focus-visible {
      background: #3b2d11;
    }

    footer {
      padding: 2rem 0 2.5rem;
      color: var(--muted);
      font-size: 0.9rem;
    }

    .footer-inner {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
    }

    @media (max-width: 820px) {
      .nav-links a:not(.nav-button) {
        display: none;
      }

      .hero-grid {
        grid-template-columns: 1fr;
      }

      .hero {
        padding-top: 7.5rem;
      }

      .visual-wrap {
        min-height: 440px;
      }

      .character-card {
        width: min(100%, 380px);
      }

      .section-heading,
      .join-panel {
        grid-template-columns: 1fr;
      }

      .section-heading {
        display: grid;
      }

      .card-grid {
        grid-template-columns: 1fr;
      }

      .events-grid {
        grid-template-columns: 1fr;
      }

      .join-panel .button {
        justify-self: start;
      }
    }

    @media (max-width: 480px) {
      .container {
        width: min(100% - 1.25rem, 1120px);
      }

      .brand {
        font-size: 0.82rem;
      }

      .nav-button {
        padding: 0.58rem 0.75rem;
        font-size: 0.8rem;
      }

      .character-image,
      .image-fallback {
        min-height: 360px;
      }

      .badge {
        right: 0;
        bottom: 1rem;
      }

      .footer-inner {
        flex-direction: column;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      html {
        scroll-behavior: auto;
      }

      *,
      *::before,
      *::after {
        transition-duration: 0.01ms !important;
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
      }
    }
  </style>
</head>

<body>
  <header class="site-header" id="siteHeader">
    <div class="container header-inner">
      <a class="brand" href="#home" aria-label="Campus Clash home">
        <span class="brand-mark">CC</span>
        <span>Campus Clash</span>
      </a>

      <nav class="nav-links" aria-label="Main navigation">
        <a href="#about">About</a>
        <a href="#events">Events</a>
        <a href="#join" class="nav-button">Join the Clash</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero" id="home">
      <div class="container hero-grid">
        <div>
          <p class="eyebrow">Culture Movement</p>

          <h1>
            Own the
            <span>Campus.</span>
          </h1>

          <p class="hero-copy">
            Campus Clash brings students together through culture, competition,
            creativity, and unforgettable community experiences.
          </p>

          <div class="hero-actions">
            <a class="button button-primary" href="#join">Join the movement</a>
            <a class="button button-secondary" href="#about">Explore Campus Clash</a>
          </div>

          <div class="hero-stats" aria-label="Campus Clash statistics">
            <div class="stat">
              <strong>10+</strong>
              <span>Campus events</span>
            </div>

            <div class="stat">
              <strong>1K+</strong>
              <span>Community voices</span>
            </div>

            <div class="stat">
              <strong>100%</strong>
              <span>Student energy</span>
            </div>
          </div>
        </div>

        <div class="visual-wrap" aria-label="Campus Clash artwork">
          <div class="glow"></div>

          <div class="character-card" id="characterCard">
            <img
              class="character-image"
              id="characterImage"
              src="logo.png"
              alt="Campus Clash logo or character artwork"
            />

            <div class="badge">
              <span>Featured</span>
              <strong>Culture. Energy. Competition.</strong>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-alt" id="about">
      <div class="container">
        <div class="section-heading">
          <h2>More than an event. A campus movement.</h2>
          <p>
            A space where students represent their identity, show their skills,
            connect with new people, and build the culture they want to see.
          </p>
        </div>

        <div class="card-grid">
          <article class="info-card">
            <span class="card-number">01 / COMPETE</span>
            <h3>Bring your best</h3>
            <p>
              Step into challenges, tournaments, showcases, and moments designed
              for people who are ready to make an impact.
            </p>
          </article>

          <article class="info-card">
            <span class="card-number">02 / CONNECT</span>
            <h3>Find your people</h3>
            <p>
              Meet collaborators, teammates, creatives, organizers, and friends
              from across the wider campus community.
            </p>
          </article>

          <article class="info-card">
            <span class="card-number">03 / CREATE</span>
            <h3>Shape the culture</h3>
            <p>
              Turn ideas into real experiences and help create the next chapter
              of student-led campus culture.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="events">
      <div class="container">
        <div class="section-heading">
          <h2>Upcoming moments</h2>
          <p>
            Replace these example events with your real Campus Clash schedule,
            venue details, and registration links.
          </p>
        </div>

        <div class="events-grid">
          <article class="event">
            <div class="event-date">
              <small>SEP</small>
              <strong>14</strong>
            </div>
            <div>
              <h3>Campus Clash Launch Night</h3>
              <p>Main Hall · 18:00 · Music, meetups, and announcements</p>
            </div>
          </article>

          <article class="event">
            <div class="event-date">
              <small>SEP</small>
              <strong>21</strong>
            </div>
            <div>
              <h3>Inter-Residence Challenge</h3>
              <p>Sports Field · 12:00 · Teams, games, and prizes</p>
            </div>
          </article>

          <article class="event">
            <div class="event-date">
              <small>OCT</small>
              <strong>05</strong>
            </div>
            <div>
              <h3>Creative Showcase</h3>
              <p>Student Centre · 17:30 · Art, style, dance, and performance</p>
            </div>
          </article>

          <article class="event">
            <div class="event-date">
              <small>OCT</small>
              <strong>19</strong>
            </div>
            <div>
              <h3>Final Clash Festival</h3>
              <p>Campus Arena · 14:00 · The main event of the season</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="join">
      <div class="container">
        <div class="join-panel">
          <div>
            <h2>Your campus. Your culture. Your clash.</h2>
            <p>
              Join Campus Clash to attend events, represent your community,
              collaborate with other students, or help organize the movement.
            </p>
          </div>

          <a
            class="button"
            href="mailto:your-email@example.com?subject=Campus%20Clash%20Registration"
          >
            Register now
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container footer-inner">
      <span>© <span id="year"></span> Campus Clash. All rights reserved.</span>
      <span>Built for campus culture.</span>
    </div>
  </footer>

  <script>
    const header = document.getElementById("siteHeader");
    const card = document.getElementById("characterCard");
    const image = document.getElementById("characterImage");
    const year = document.getElementById("year");

    year.textContent = new Date().getFullYear();

    function updateHeader() {
      header.classList.toggle("is-scrolled", window.scrollY > 20);
    }

    updateHeader();
    window.addEventListener("scroll", updateHeader, { passive: true });

    window.addEventListener(
      "scroll",
      () => {
        const scrollAmount = Math.min(window.scrollY, 700);
        const rotateY = scrollAmount * 0.018;
        const rotateX = -scrollAmount * 0.008;
        const translateY = scrollAmount * -0.035;

        card.style.transform =
          `rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(${translateY}px)`;
      },
      { passive: true }
    );

    image.addEventListener("error", () => {
      const fallback = document.createElement("div");
      fallback.className = "image-fallback";
      fallback.innerHTML = `
        <div>
          <strong>Campus<br>Clash</strong>
          <span>Add logo.png to display your artwork</span>
        </div>
      `;

      image.replaceWith(fallback);
    });
  </script>
</body>
</html>
